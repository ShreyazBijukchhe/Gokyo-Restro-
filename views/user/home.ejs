<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Gokyo Bistro</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f5f0e8; }
        .navbar { background: #2c1810; color: white; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; }
        .navbar a { color: white; text-decoration: none; margin: 0 0.5rem; }
        .logo { font-size: 1.5rem; font-weight: bold; }
        .container { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }
        .btn { background: #d4a373; color: white; padding: 0.5rem 1.5rem; border: none; border-radius: 5px; cursor: pointer; text-decoration: none; display: inline-block; }
        .btn:hover { background: #b88352; }
        .card { background: white; border-radius: 10px; padding: 1.5rem; margin: 1rem 0; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .error { color: red; padding: 0.5rem; margin: 0.5rem 0; }
        .success { color: green; }
        footer { background: #2c1810; color: white; text-align: center; padding: 1rem; margin-top: 2rem; }
        .hero { text-align: center; padding: 3rem; background: linear-gradient(135deg, #2c1810, #5c3a2a); color: white; border-radius: 10px; margin-bottom: 2rem; }
        .hero h1 { font-size: 2.5rem; margin-bottom: 1rem; }
        .offer-card { border-left: 4px solid #d4a373; padding: 0.5rem; margin: 0.5rem 0; }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="logo">🍽️ Gokyo Bistro</div>
        <div>
            <a href="/home">Home</a>
            <a href="/booking">Book Table</a>
            <a href="/menu">Order Food</a>
            <a href="/offers">Offers</a>
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/my-bookings">My Bookings</a>
                <% if (user.type === 'Admin') { %>
                    <a href="/admin/dashboard">Admin</a>
                <% } %>
                <span>👤 <%= user.name %></span>
                <a href="/logout">Logout</a>
            <% } else { %>
                <a href="/login">Sign In</a>
                <a href="/register">Register</a>
            <% } %>
        </div>
    </nav>
    <div class="container">
        <div class="hero">
            <h1>Gokyo Bistro</h1>
            <p>Jhamsikhel, Lalitpur</p>
            <div style="margin-top: 1rem;">
                <a href="/booking" class="btn" style="margin: 0.5rem;">📅 Book a Table</a>
                <a href="/menu" class="btn" style="margin: 0.5rem;">🍔 Order Food</a>
            </div>
        </div>

        <div class="card">
            <h2>Current Offers</h2>
            <% if (typeof offers !== 'undefined' && offers && offers.length > 0) { %>
                <% for(var i = 0; i < offers.length; i++) { %>
                    <div class="offer-card">
                        <strong><%= offers[i].offer_title %></strong> - <%= offers[i].description %>
                        <span style="color: green;">Active</span>
                    </div>
                <% } %>
            <% } else { %>
                <p>No active offers at the moment.</p>
            <% } %>
        </div>
    </div>
    <footer>
        <p>&copy; 2026 Gokyo Bistro | Jhamsikhel, Lalitpur | All Rights Reserved</p>
    </footer>
</body>
</html>