<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Gokyo Bistro</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f5f0e8; }
        .container { max-width: 500px; margin: 3rem auto; padding: 0 1rem; }
        .card { background: white; border-radius: 10px; padding: 2rem; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .btn { background: #d4a373; color: white; padding: 0.5rem 1.5rem; border: none; border-radius: 5px; cursor: pointer; width: 100%; }
        .btn:hover { background: #b88352; }
        input, select { width: 100%; padding: 0.5rem; margin-top: 0.25rem; border: 1px solid #ddd; border-radius: 5px; }
        .error { color: red; margin-bottom: 1rem; }
        h2 { margin-bottom: 0.5rem; }
        h3 { margin-bottom: 1rem; color: #666; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h2>Welcome Back</h2>
            <h3>Sign in to your account</h3>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error"><%= error %></div>
            <% } %>
            <form method="POST" action="/login">
                <div style="margin: 1rem 0;">
                    <label>Email address</label>
                    <input type="email" name="email" required>
                </div>
                <div style="margin: 1rem 0;">
                    <label>Password</label>
                    <input type="password" name="password" required>
                </div>
                <button type="submit" class="btn">Sign In</button>
            </form>
            <p style="margin-top: 1rem; text-align: center;">Don't have an account? <a href="/register">Register here</a></p>
        </div>
    </div>
</body>
</html>